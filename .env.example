# Server-side API keys for the research pipeline.
# Copy this file to `.env` and fill in the keys you have.
# These are read ONLY by the Express backend (server/) and never sent to the browser.

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq — https://console.groq.com/keys
GROQ_API_KEY=

# Optional: Semantic Scholar key for higher rate limits on literature search.
# Without it the backend still works but may be throttled (it retries on 429).
# Request one at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Port the backend API listens on (frontend dev server proxies /api here).
PORT=8787
